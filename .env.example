# Confluent Cloud Configuration
# Copy this file to .env and fill in your actual values

# Bootstrap server - find this in your cluster's "Cluster Overview"
# Example: pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_BOOTSTRAP_SERVERS=your-bootstrap-server-here:9092

# API credentials - create these in "API Keys" section of Confluent Cloud
CONFLUENT_API_KEY=YOUR_API_KEY_HERE
CONFLUENT_API_SECRET=YOUR_API_SECRET_HERE
